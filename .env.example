VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=
VITE_SENTRY_TRACES_SAMPLE_RATE=

# Supabase (CLI / Edge Functions deploy)
SUPABASE_ACCESS_TOKEN=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=
SUPABASE_PROJECT_REF=

# Sentry (build upload + issue inspection)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_BASE_URL=

# Mercado Pago (configure as Supabase Edge Function secrets)
# supabase secrets set MERCADOPAGO_ACCESS_TOKEN=... MERCADOPAGO_WEBHOOK_TOKEN=... MERCADOPAGO_WEBHOOK_SECRET=... --project-ref <ref>
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_PAYOUTS_URL=https://api.mercadopago.com/v1/transfers
MERCADOPAGO_PAYOUTS_STATUS_URL_TEMPLATE=https://api.mercadopago.com/v1/transfers/{id}
MERCADOPAGO_PAYOUT_TIMEOUT_MS=15000
WITHDRAWAL_WORKER_TOKEN=
WITHDRAWAL_WORKER_DEFAULT_LIMIT=20
WITHDRAWAL_WORKER_MAX_LIMIT=100
WITHDRAWAL_WORKER_MAX_RETRIES=8

# Optional (only if you want to override Supabase URL for frontend calls)
VITE_API_URL=

# VPS Deploy (scripts)
VPS_HOST=
VPS_USER=
VPS_PORT=
# Use VPS_PASSWORD only for the one-time key provisioning (scripts/provision_vps_ssh_key.cjs).
# Prefer SSH key auth for deploy scripts.
VPS_PASSWORD=
# Path to the SSH private key file (optional if you keep ~/.ssh/fatopago_key).
VPS_KEY_PATH=

# News worker retention (optional)
# Keep only the last 48h of news_tasks (and related validations).
NEWS_RETENTION_DAYS=2
NEWS_RETENTION_RUN_INTERVAL_MS=172800000

# News worker throughput profile (lower load)
NEWS_POLL_INTERVAL_MS=180000
NEWS_PER_FEED_LIMIT=8
MEIO_NEWS_PRIORITY_COUNT=10
RSS_SCAN_PER_FEED=4
NEWS_RECENT_WINDOW=1000
A
Z
