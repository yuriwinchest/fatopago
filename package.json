{
  "name": "fatopago",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest",
    "preview": "vite preview",
    "pack": "node scripts/pack_app.cjs",
    "deploy": "node --env-file=.env scripts/remote_deploy.cjs",
    "deploy:quick": "node scripts/deploy_quick.cjs",
    "vps:provision-key": "node scripts/provision_vps_ssh_key.cjs",
    "vps:ssh:harden": "node scripts/harden_vps_ssh_auth.cjs",
    "vps:security-report": "node scripts/run_vps_security_report.cjs",
    "fix-logo": "python scripts/process_new_logo.py",
    "ship": "npm run pack && npm run deploy"
  },
  "dependencies": {
    "@sentry/react": "^10.46.0",
    "@supabase/supabase-js": "^2.39.0",
    "@types/react-input-mask": "^3.0.6",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.562.0",
    "node-ssh": "^13.2.1",
    "pg": "^8.18.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-input-mask": "^2.0.4",
    "react-router-dom": "^6.20.0",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "^5.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.57.1",
    "eslint-plugin-react-refresh": "^0.4.4",
    "glob": "^13.0.0",
    "jsdom": "^27.4.0",
    "postcss": "^8.4.31",
    "rimraf": "^6.1.2",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
